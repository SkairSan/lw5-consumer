{
    "name": "skairsan/pizza-store-consumer",
    "description": "Sample project that uses the pizza store library.",
    "type": "project",
    "require": {
        "skairsan/pizza-store-lib": "dev-main"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/SkairSan/lw5.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "PizzaStoreConsumer\\": "src/",
            "PizzaStoreLib\\": "vendor/skairsan/pizza-store-lib/src/"
        }
    },
    "license": "MIT",
    "require-dev": {
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1"
    }
}
